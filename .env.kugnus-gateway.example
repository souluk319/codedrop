# Owner/private KUGNUS SERVER reference.
# KUGNUS is not required for public CodeDrop clones.
# For normal setup, use GEMINI_API_KEY or OPENAI_API_KEY in .env.local.
# Uncomment this block only if you operate the same OpenAI-compatible gateway.

# DEFAULT_CHAT_ENGINE=kugnus

# KUGNUS SERVER via an owner-operated OpenAI-compatible gateway.
# KUGNUS_GATEWAY_BASE_URL=https://llm.example.com/v1
# KUGNUS_GATEWAY_API_KEY=<KUGNUS_GATEWAY_API_KEY>
# KUGNUS_GATEWAY_MODEL=gemma4:12b-it-qat
# Optional alias:
# KUGNUS_CHAT_MODEL=gemma4:12b-it-qat

# Optional owner/private embedding alias.
# KUGNUS_EMBED_MODEL=embeddinggemma:latest

# Pack Maker may need more time for 50+ item KUGNUS generations.
# PACK_MAKER_TIMEOUT_MS=600000
# PACK_MAKER_BATCH_TIMEOUT_MS=180000
