# KUGNUS public gateway handoff template.
# Use this when connecting the local-llm-lab OpenAI-compatible gateway.
# Copy the real values into your local or deployment env. Do not commit secrets.

DEFAULT_CHAT_ENGINE=kugnus

# KUGNUS SERVER via the public OpenAI-compatible gateway.
OPENAI_BASE_URL=https://llm.yourdomain.com/v1
OPENAI_API_KEY=<KUGNUS_GATEWAY_API_KEY>
OPENAI_MODEL=gemma4:12b-it-qat

# Keep GPT fallback separate when OPENAI_* is used for KUGNUS.
GPT_OPENAI_BASE_URL=https://api.openai.com/v1
GPT_OPENAI_API_KEY=<OPENAI_API_KEY>
GPT_OPENAI_MODEL=gpt-5.4-mini

# Gateway embedding profile for the next RAG/search grounding pass.
EMBEDDING_MODEL=embeddinggemma:latest
KUGNUS_EMBEDDING_MODEL=embeddinggemma:latest
KUGNUS_EMBEDDING_DIMENSIONS=768

# Pack Maker needs enough time for 50+ item KUGNUS generations.
PACK_MAKER_TIMEOUT_MS=600000
PACK_MAKER_BATCH_TIMEOUT_MS=180000

# Release must not use the direct local/private Ollama route.
ALLOW_DIRECT_KUGNUS=0
