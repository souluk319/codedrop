#
# CodeDrop local development template.
# Copy to .env.local and fill only the values you need.
# Keep real API keys, admin emails, and deployment-specific values out of git.
#

DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=codedrop
DB_PASSWORD=codedrop_pw
DB_NAME=codedrop_db
DB_SSL=false

SESSION_SECRET=codedrop-local-dev-session-secret-change-for-release
ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001
PACK_ADMIN_NICKNAMES=admin
DEFAULT_CHAT_ENGINE=gemini

PACK_MAKER_TIMEOUT_MS=600000
PACK_MAKER_BATCH_TIMEOUT_MS=180000

# GPT fallback. Keep this mini-only; server rejects non-mini OpenAI models.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Optional comparison engine for Learn Chat and Pack Maker.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=120000

# Owner/private KUGNUS SERVER path.
# Leave commented unless you operate the same OpenAI-compatible gateway.
# DEFAULT_CHAT_ENGINE=kugnus
# KUGNUS_GATEWAY_BASE_URL=https://llm.example.com/v1
# KUGNUS_GATEWAY_API_KEY=<KUGNUS_GATEWAY_API_KEY>
# KUGNUS_GATEWAY_MODEL=gemma4:12b-it-qat
# KUGNUS_CHAT_MODEL=gemma4:12b-it-qat

# Pack Maker search grounding.
DUCKDUCKGO_API_KEY=

# Optional public review email notification.
# Real keys and recipient addresses stay in .env/deployment secrets only.
RESEND_API_KEY=
REVIEW_NOTIFY_EMAIL=
MAIL_FROM=CodeDrop <notifications@example.com>
PUBLIC_APP_URL=http://localhost:3001/games/codedrop

# Future RAG/search-index options. Current pack save logic does not require them.
EMBEDDING_MODEL=embeddinggemma:latest
# Owner/private KUGNUS embedding alias:
# KUGNUS_EMBED_MODEL=embeddinggemma:latest
EMBEDDING_DIMENSIONS=768
