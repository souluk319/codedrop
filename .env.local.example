DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=codedrop
DB_PASSWORD=codedrop_pw
DB_NAME=codedrop_db
DB_SSL=false

SESSION_SECRET=codedrop-local-dev-session-secret-change-for-release
ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001
PACK_ADMIN_NICKNAMES=test
DEFAULT_CHAT_ENGINE=kugnus

# KUGNUS SERVER gateway (OpenAI-compatible).
# CodeDrop reads only these KUGNUS variables.
# After filling release-like values locally, verify the actual server route:
#   npm run verify:release-runtime -- --env-file=.env.local
KUGNUS_GATEWAY_BASE_URL=
KUGNUS_GATEWAY_API_KEY=
KUGNUS_GATEWAY_MODEL=gemma4:12b-it-qat
PACK_MAKER_TIMEOUT_MS=600000
PACK_MAKER_BATCH_TIMEOUT_MS=180000

# GPT fallback. Keep this mini-only; server rejects non-mini OpenAI models.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Pack Maker search grounding.
DUCKDUCKGO_API_KEY=

# Future RAG/search-index options. Current pack save logic does not require them.
EMBEDDING_MODEL=embeddinggemma:latest
EMBEDDING_DIMENSIONS=768
