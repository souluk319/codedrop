# CodeDrop production environment template.
# Copy these values into your deployment platform, not into browser code.

NODE_ENV=production
PORT=3001

# Public app origin(s). Comma-separated.
ALLOWED_ORIGINS=https://codedrop.example.com

# Session signing. Use a long random value in production.
SESSION_SECRET=

# MySQL-compatible production database.
DB_HOST=
DB_PORT=4000
DB_USER=
DB_PASSWORD=
DB_NAME=codedrop_db
DB_SSL=true

# Product/admin policy.
DEFAULT_CHAT_ENGINE=kugnus
PACK_ADMIN_NICKNAMES=

# KUGNUS SERVER public gateway (OpenAI-compatible).
# Use the gateway values from local-llm-lab:
#   OPENAI_BASE_URL=https://llm.yourdomain.com/v1
#   OPENAI_API_KEY=<KUGNUS_GATEWAY_API_KEY>
#   OPENAI_MODEL=gemma4:12b-it-qat
KUGNUS_GATEWAY_BASE_URL=
KUGNUS_GATEWAY_API_KEY=
KUGNUS_MODEL=gemma4:12b-it-qat
KUGNUS_EMBEDDING_MODEL=embeddinggemma:latest
KUGNUS_EMBEDDING_DIMENSIONS=768

# GPT fallback. Keep this mini-only; server rejects non-mini OpenAI models.
GPT_OPENAI_BASE_URL=https://api.openai.com/v1
GPT_OPENAI_API_KEY=
GPT_OPENAI_MODEL=gpt-5.4-mini

# Search grounding for Pack Maker.
DUCKDUCKGO_API_KEY=

# Do not set LLM_BASE_URL in production unless you intentionally accept
# direct local/private routing and set ALLOW_DIRECT_KUGNUS=1.
ALLOW_DIRECT_KUGNUS=0
