# CodeDrop production environment template.
# Copy these values into your deployment platform, not into browser code.
# Replace every example.com value with your real deployment values.

NODE_ENV=production
PORT=3001

# Public app origin(s). Comma-separated.
# Example public URL: https://codedrop.example.com/games/codedrop/
ALLOWED_ORIGINS=https://codedrop.example.com

# Session signing. Generate with: npm run release:secret
SESSION_SECRET=

# MySQL-compatible production database.
DB_HOST=
DB_PORT=4000
DB_USER=
DB_PASSWORD=
DB_NAME=codedrop_db
DB_SSL=true

# Product/admin policy.
DEFAULT_CHAT_ENGINE=kugnus
PACK_ADMIN_NICKNAMES=

# KUGNUS SERVER public gateway (OpenAI-compatible).
# CodeDrop prefers KUGNUS_GATEWAY_MODEL and also accepts KUGNUS_CHAT_MODEL.
# After filling release values, verify the actual server route:
#   npm run verify:release-runtime -- --env-file=.env.production
KUGNUS_GATEWAY_BASE_URL=
KUGNUS_GATEWAY_API_KEY=
KUGNUS_GATEWAY_MODEL=gemma4:12b-it-qat
# Alias accepted from the public gateway project:
# KUGNUS_CHAT_MODEL=gemma4:12b-it-qat
PACK_MAKER_TIMEOUT_MS=600000
PACK_MAKER_BATCH_TIMEOUT_MS=180000

# GPT fallback. Keep this mini-only; server rejects non-mini OpenAI models.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Optional comparison engine for Learn Chat and Pack Maker.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=120000

# Search grounding for Pack Maker.
DUCKDUCKGO_API_KEY=

# Public review email notification.
# Set real values only in deployment secrets.
RESEND_API_KEY=
REVIEW_NOTIFY_EMAIL=admin@example.com
MAIL_FROM=CodeDrop <notifications@example.com>
PUBLIC_APP_URL=https://codedrop.example.com/games/codedrop

# Future RAG/search-index options. Current pack save logic does not require them.
EMBEDDING_MODEL=embeddinggemma:latest
# Alias accepted from the public gateway project:
# KUGNUS_EMBED_MODEL=embeddinggemma:latest
EMBEDDING_DIMENSIONS=768
