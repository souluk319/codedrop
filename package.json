{
  "name": "codedrop",
  "version": "1.0.0",
  "type": "module",
  "description": "",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test": "npm run verify",
    "verify": "node scripts/verify_all.mjs",
    "verify:5x": "node scripts/verify_5x.mjs",
    "verify:db": "node scripts/verify_db_e2e.mjs",
    "verify:packmaker:kugnus": "node scripts/verify_packmaker_kugnus_e2e.mjs",
    "audit:prod": "npm audit --omit=dev --audit-level=moderate",
    "release:check": "node scripts/check_release_readiness.mjs",
    "db:local:up": "docker compose -f docker-compose.local.yml up -d",
    "db:local:down": "docker compose -f docker-compose.local.yml down",
    "db:local:reset": "docker compose -f docker-compose.local.yml down -v && docker compose -f docker-compose.local.yml up -d"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "mysql2": "^3.15.3"
  },
  "overrides": {
    "path-to-regexp": "^8.4.2",
    "qs": "^6.15.3"
  }
}
